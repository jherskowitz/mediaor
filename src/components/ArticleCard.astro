---
interface Props {
  title: string;
  link: string;
  description: string;
  pubDate: Date;
  source: string;
  sourceUrl?: string;
  image?: string;
  category?: string;
  categorySlug?: string;
}

const { title, link, description, pubDate, source, sourceUrl, image, category, categorySlug } = Astro.props;

function getFaviconUrl(sourceUrl?: string, articleLink?: string): string {
  try {
    const url = sourceUrl || articleLink || '';
    const domain = new URL(url).hostname;
    return `https://www.google.com/s2/favicons?domain=${domain}&sz=16`;
  } catch {
    return '';
  }
}

const faviconUrl = getFaviconUrl(sourceUrl, link);

function timeAgo(date: Date): string {
  const seconds = Math.floor((Date.now() - date.getTime()) / 1000);
  if (seconds < 60) return 'just now';
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
}
---

<article class="card">
  {image && (
    <div class="card-image">
      <img src={image} alt="" loading="lazy" />
    </div>
  )}
  <div class="card-body">
    {category && categorySlug && (
      <a href={`/${categorySlug}`} class={`card-badge badge-${categorySlug}`}>{category}</a>
    )}
    <a href={link} target="_blank" rel="noopener noreferrer" class="card-title">
      {title}
    </a>
    <p class="card-description">{description}</p>
    <div class="card-meta">
      <span class="card-source">
        {faviconUrl && <img src={faviconUrl} alt="" class="source-favicon" loading="lazy" />}
        {source}
      </span>
      <span class="card-time">{timeAgo(pubDate)}</span>
    </div>
  </div>
</article>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.15s;
  }

  .card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-border);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-badge {
    font-size: 0.675rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    width: fit-content;
    color: #fff;
    background: #6b7280;
  }

  .badge-music-tech { background: #7c3aed; }
  .badge-music { background: #db2777; }
  .badge-tech { background: #2563eb; }
  .badge-industry { background: #d97706; }
  .badge-general { background: #6b7280; }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .card-meta {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .card-source {
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .source-favicon {
    width: 14px;
    height: 14px;
    border-radius: 2px;
  }
</style>
